# ====== Variáveis do backend (Spring Boot) ======
# No Railway, configure estas como variáveis de ambiente do serviço.
# Linhas marcadas com (SEGREDO) NÃO podem ir para o Git — só no painel do Railway.

# === Banco de dados (PostgreSQL) ===
# Railway normalmente injeta as do plugin Postgres; aponte para o banco de produção.
DB_URL=jdbc:postgresql://<host>:<port>/<database>
DB_USER=
DB_PASSWORD=                 # (SEGREDO)

# Hibernate (opcionais; defaults: update / true)
# DDL_AUTO=update
# SHOW_SQL=false

# === CORS ===
# Origens permitidas (separadas por vírgula). Em produção: a URL do front na Vercel.
# Aceita curinga: https://*.vercel.app cobre os previews; some a URL final também.
CORS_ALLOWED_ORIGINS=https://seu-front.vercel.app,https://*.vercel.app

# === JWT ===
JWT_SECRET=                  # (SEGREDO) >= 32 bytes aleatórios. NÃO use o default de dev.
# JWT_EXPIRATION=86400000    # opcional (ms; default 24h)

# === Admin inicial (seed) ===
ADMIN_EMAIL=admin@patudosdarua.com.br
ADMIN_PASSWORD=              # (SEGREDO) senha forte do admin
ADMIN_NOME=Administrador Patudos

# === E-mail (códigos de verificação / recuperação de senha) ===
# ATUAL: Gmail com "Senha de app" (sem domínio próprio). Envia para QUALQUER destinatário.
# Requer verificação em 2 etapas ativada na conta Google.
APP_EMAIL_ENABLED=true
APP_FROM_EMAIL=conta-da-ong@gmail.com
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=conta-da-ong@gmail.com
SPRING_MAIL_PASSWORD=        # (SEGREDO) Senha de app do Gmail (16 caracteres)
#
# FUTURO (quando tiver domínio verificado): migrar para Resend trocando SÓ estas vars (sem mexer no código):
#   SPRING_MAIL_HOST=smtp.resend.com  ·  SPRING_MAIL_USERNAME=resend
#   SPRING_MAIL_PASSWORD=<API key re_...>  ·  APP_FROM_EMAIL=nao-responder@<dominio-verificado>

# === Login com Google ===
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com   # público (mesmo do front)

# OBS: o Railway injeta PORT automaticamente; não precisa setar.
